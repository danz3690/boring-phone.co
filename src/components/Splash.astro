---
import { siteMeta } from '../data/research';
---

<section class="splash" id="top">
  <div class="marquee" role="marquee">
    <span
      >★ WELCOME TO BORING-PHONE.CO ★ &nbsp; Netscape Navigator 3.0 recommended
      &nbsp; ★ &nbsp; NOW WITH 100% REAL SCIENCE &nbsp; ★ &nbsp; turn your sound
      ON &nbsp; ★ &nbsp; sign the guestbook!!! &nbsp; ★</span
    >
  </div>

  <p class="center"><span class="globe-spin" aria-hidden="true">🌐</span></p>
  <h1 class="splash__logo">boring&#8209;phone<span class="blink">.co</span></h1>
  <p class="splash__sub comic">
    A <b>dopamine detox</b> homepage — built like it's 1996, sourced like it's
    2025.
  </p>

  <p class="center">
    <button
      id="enter-btn"
      class="btn95"
      type="button"
      aria-label="Enter the site and turn on sound"
    >
      &#9654;&nbsp; ENTER SITE (sound on) &nbsp;&#9664;
    </button>
  </p>
  <p class="center small muted">
    Clicking ENTER dials up the modem 📞 and turns on retro sound effects. You
    can mute anytime with the button in the corner.
  </p>

  <div class="construction">
    <span>🚧 THIS SITE IS UNDER CONSTRUCTION 🚧</span>
  </div>

  <p class="center small muted">
    You are visitor
    <span class="counter__digits">{siteMeta.hitCount}</span> &nbsp;•&nbsp; Best
    viewed at 800×600
  </p>

  <hr class="rainbow-hr" />
</section>
